---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
const pageTitle = "Smaller Projects";
---
<Layout pageTitle={pageTitle}>
    
    <div class="card-grid">
         <Card
            url="/projects/small_projects/seatpost_clamp"
            image="/small_projects/seatpost_clamp/finished1.webp"
            title="Custom Seatpost Clamps"
        />
        <Card
            url="/projects/small_projects/picture_frames"
            image="/small_projects/picture_frame/finished_single.webp"
            title="Billet Picture Frames"
        />
        <Card
            url="/projects/small_projects/cutting_board"
            image="/small_projects/cutting_board/oiled.webp"
            title="End Grain Cutting Board"
        />
        <Card
            url="/projects/small_projects/PCB_design"
            image="/small_projects/PCB/layout.webp"
            title="PCB Design"
        />
        <Card
            url="/projects/small_projects/5axis"
            image="/small_projects/5axis/before_tabs.webp"
            title="5 Axis Machining"
        />
        <Card
            url="/projects/small_projects/cnc_cert"
            image="/major_projects/polysat/cnc_mill.webp"
            title="CNC Machining"
        />
        <Card
            url="/projects/small_projects/pens"
            image="/small_projects/pen/cover_img.webp"
            title="Machined Bolt Action Pen"
        />
    </div>
        
</Layout>


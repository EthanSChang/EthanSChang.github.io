---
import Layout from '../layouts/Layout.astro';
const pageTitle = "Ethan Chang Portfolio";
---
<Layout pageTitle={pageTitle}>
    <div class="main">
         
         <div id="img-title">
            <img id = "headshot-img" src = "/headshot.jpg">

            <div id="title-navbar">
               <h1 id="name">Ethan Chang</h1>
               <p>
                  Mechanical Engineering, Cal Poly SLO
               </p>
        
               <div id="main-navbar">
                  <a href ="https://www.linkedin.com/in/ethan-chang-2b56562a0/" > 
                     <div class="btn" >
                        <img class = "svg-icon" src ="/icons/linkedin.svg" >
                        <p class="accent"> LinkedIn </p>
                     </div>
                  </a>
                  <a href ="mailto:chang.sh.ethan@gmail.com" > 
                     <div class="btn" >
                        <img class = "svg-icon" src ="/icons/email.svg" >
                        <p class="accent"> chang.sh.ethan@gmail.com </p>
                     </div>
                  </a>
                  <a href ="https://ethanschang.github.io/photo-portfolio/" > 
                     <div class="btn" >
                        <img class = "svg-icon" src ="/icons/camera.svg" >
                        <p class="accent"> Photography Portfolio </p>
                     </div>
                  </a>
               </div>
            </div>
            
            
         </div>
         <div id="body_text">
            <p>
               Hello! I'm a third year mechanical engineering student at Cal Poly SLO, concentrating in mechatronics. I'm currently interning with the Starship Build Engineering team at SpaceX.
               In college I am part of <a class="accent" href="https://www.calpolybikebuilders.com/">Cal Poly Bike Builders</a> as a club officer.
               I also work for the <a class="accent" href="https://machineshops.calpoly.edu/">Cal Poly Machine Shops</a>, where I get to supervise the student machine shop and teach students machining skills. 
               This website is a repository for all my projects and activities.
            </p>
         </div>
         
         
         <!-- <div id="bottom-links">
            <a class="link-large" href ="/projects/">
               <p class="accent">Projects</p>
            </a>
            <a class="link-large" href ="/resume/">
               <p class="accent">Resume</p>
            </a>    

         </div>
         -->
    </div>
    
</Layout>

